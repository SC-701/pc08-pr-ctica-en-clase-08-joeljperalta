@page
@model IndexModel
@{
    ViewData["Title"] = "Listado de Productos";
}

<h1>Listado de Productos</h1>

<div class="container">
    <div class="text-center mb-4">
        <a type="button" class="btn btn-primary" asp-page="./Agregar">Agregar</a>
    </div>

    <div class="row">
        @if (Model.productos != null)
        {
            @foreach (var producto in Model.productos)
            {
                <div class="col-md-4 mb-4">
                    <div class="card">
                        <div class="card-body">
                            <h5 class="card-title">@producto.Nombre</h5>
                            <h6 class="card-subtitle mb-2 text-muted">@producto.Categoria / @producto.SubCategoria</h6>
                            <p class="card-text">@producto.Descripcion</p>
                            <p class="card-text"><b>Precio:</b> $@producto.Precio</p>
                            <p class="card-text"><b>Stock:</b> @producto.Stock</p>
                            <a type="button" class="btn btn-primary" asp-page="./Detalle" asp-route-id="@producto.Id">Detalles</a>
                            <a type="button" class="btn btn-warning" asp-page="./Editar" asp-route-id="@producto.Id">Editar</a>
                            <a type="button" class="btn btn-danger" asp-page="./Eliminar" asp-route-id="@producto.Id">Eliminar</a>
                        </div>
                    </div>
                </div>
            }
        }
    </div>
</div>